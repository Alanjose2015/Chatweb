<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chat App - Comunicación en Tiempo Real</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary: #0EA5E9;
            --primary-dark: #0284C7;
            --secondary: #10B981;
            --background: #FFFFFF;
            --surface: #F8F9FA;
            --surface-dark: #F1F5F9;
            --text-primary: #1F2937;
            --text-secondary: #6B7280;
            --border: #E5E7EB;
            --success: #10B981;
            --error: #EF4444;
            --warning: #F59E0B;
            --radius: 0.65rem;
            --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
            --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', sans-serif;
            background: var(--background);
            color: var(--text-primary);
            height: 100vh;
            overflow: hidden;
        }

        .container {
            display: flex;
            height: 100vh;
        }

        /* Sidebar */
        .sidebar {
            width: 280px;
            background: var(--surface);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            box-shadow: var(--shadow-sm);
        }

        .sidebar-header {
            padding: 1.5rem;
            border-bottom: 1px solid var(--border);
        }

        .sidebar-title {
            font-size: 1.25rem;
            font-weight: 700;
            color: var(--text-primary);
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .sidebar-title::before {
            content: '💬';
            font-size: 1.5rem;
        }

        .users-section {
            flex: 1;
            overflow-y: auto;
            padding: 1rem;
        }

        .users-label {
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            color: var(--text-secondary);
            margin-bottom: 0.75rem;
            padding: 0 0.5rem;
            letter-spacing: 0.05em;
        }

        .user-item {
            padding: 0.75rem;
            margin-bottom: 0.5rem;
            border-radius: var(--radius);
            background: var(--background);
            border: 1px solid transparent;
            cursor: pointer;
            transition: all 200ms ease-out;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .user-item:hover {
            background: var(--surface-dark);
            border-color: var(--border);
        }

        .user-item.active {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
        }

        .user-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 600;
            font-size: 0.75rem;
        }

        .user-item.active .user-avatar {
            background: rgba(255, 255, 255, 0.3);
        }

        .user-info {
            flex: 1;
            min-width: 0;
        }

        .user-name {
            font-size: 0.875rem;
            font-weight: 500;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .user-status {
            font-size: 0.75rem;
            opacity: 0.7;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .status-indicator {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--success);
            flex-shrink: 0;
        }

        /* Main Chat Area */
        .chat-container {
            flex: 1;
            display: flex;
            flex-direction: column;
            background: var(--background);
        }

        .chat-header {
            padding: 1.5rem;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: var(--surface);
            box-shadow: var(--shadow-sm);
        }

        .chat-header-title {
            font-size: 1.125rem;
            font-weight: 600;
            color: var(--text-primary);
        }

        .chat-header-subtitle {
            font-size: 0.875rem;
            color: var(--text-secondary);
            margin-top: 0.25rem;
        }

        .chat-header-info {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .online-count {
            font-size: 0.875rem;
            color: var(--text-secondary);
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .online-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--success);
        }

        /* Messages Area */
        .messages {
            flex: 1;
            overflow-y: auto;
            padding: 1.5rem;
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .message {
            display: flex;
            gap: 0.75rem;
            animation: slideIn 200ms ease-out;
        }

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .message.own {
            justify-content: flex-end;
        }

        .message-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 600;
            font-size: 0.75rem;
            flex-shrink: 0;
        }

        .message-content {
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
            max-width: 60%;
        }

        .message.own .message-content {
            align-items: flex-end;
        }

        .message-header {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.875rem;
        }

        .message-author {
            font-weight: 600;
            color: var(--text-primary);
        }

        .message-time {
            color: var(--text-secondary);
            font-size: 0.75rem;
        }

        .message.own .message-author {
            color: var(--primary);
        }

        .message-bubble {
            padding: 0.75rem 1rem;
            border-radius: var(--radius);
            word-wrap: break-word;
            word-break: break-word;
            box-shadow: var(--shadow-sm);
            line-height: 1.5;
        }

        .message-bubble {
            background: var(--surface);
            color: var(--text-primary);
            border: 1px solid var(--border);
        }

        .message.own .message-bubble {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
        }

        .empty-state {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100%;
            color: var(--text-secondary);
            text-align: center;
        }

        .empty-state-icon {
            font-size: 3rem;
            margin-bottom: 1rem;
            opacity: 0.5;
        }

        .empty-state-text {
            font-size: 1rem;
            margin-bottom: 0.5rem;
        }

        .empty-state-subtext {
            font-size: 0.875rem;
            opacity: 0.7;
        }

        /* Input Area */
        .input-area {
            padding: 1.5rem;
            border-top: 1px solid var(--border);
            background: var(--surface);
            display: flex;
            gap: 0.75rem;
        }

        .input-wrapper {
            flex: 1;
            display: flex;
            gap: 0.5rem;
            align-items: center;
        }

        .message-input {
            flex: 1;
            padding: 0.75rem 1rem;
            border: 1px solid var(--border);
            border-radius: var(--radius);
            font-family: inherit;
            font-size: 0.875rem;
            color: var(--text-primary);
            background: var(--background);
            resize: none;
            max-height: 100px;
            transition: all 200ms ease-out;
        }

        .message-input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.1);
        }

        .message-input::placeholder {
            color: var(--text-secondary);
        }

        .send-button {
            padding: 0.75rem 1.5rem;
            background: var(--primary);
            color: white;
            border: none;
            border-radius: var(--radius);
            font-weight: 600;
            cursor: pointer;
            transition: all 200ms ease-out;
            display: flex;
            align-items: center;
            justify-content: center;
            min-width: 44px;
            height: 44px;
            font-size: 1.25rem;
        }

        .send-button:hover:not(:disabled) {
            background: var(--primary-dark);
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
        }

        .send-button:active:not(:disabled) {
            transform: translateY(0);
        }

        .send-button:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        /* Scrollbar */
        ::-webkit-scrollbar {
            width: 6px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: var(--border);
            border-radius: 3px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: var(--text-secondary);
        }

        /* Responsive */
        @media (max-width: 768px) {
            .sidebar {
                width: 240px;
            }

            .message-content {
                max-width: 80%;
            }

            .chat-header {
                padding: 1rem;
            }

            .messages {
                padding: 1rem;
            }

            .input-area {
                padding: 1rem;
            }
        }

        @media (max-width: 640px) {
            .container {
                flex-direction: column;
            }

            .sidebar {
                width: 100%;
                height: auto;
                max-height: 200px;
                border-right: none;
                border-bottom: 1px solid var(--border);
            }

            .users-section {
                display: flex;
                gap: 0.5rem;
                overflow-x: auto;
                padding: 1rem;
            }

            .user-item {
                flex-shrink: 0;
                width: auto;
                margin-bottom: 0;
            }

            .chat-container {
                height: auto;
                flex: 1;
            }

            .message-content {
                max-width: 90%;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Sidebar -->
        <div class="sidebar">
            <div class="sidebar-header">
                <div class="sidebar-title">Chat App</div>
            </div>
            <div class="users-section" id="usersList">
                <div class="users-label">Usuarios conectados</div>
                <!-- Users will be populated here -->
            </div>
        </div>

        <!-- Chat Area -->
        <div class="chat-container">
            <div class="chat-header">
                <div>
                    <div class="chat-header-title" id="selectedUserName">Selecciona un usuario</div>
                    <div class="chat-header-subtitle" id="selectedUserStatus">Conectado</div>
                </div>
                <div class="chat-header-info">
                    <div class="online-count">
                        <div class="online-dot"></div>
                        <span id="onlineCount">0 conectados</span>
                    </div>
                </div>
            </div>

            <div class="messages" id="messagesList">
                <div class="empty-state">
                    <div class="empty-state-icon">💬</div>
                    <div class="empty-state-text">Bienvenido al Chat</div>
                    <div class="empty-state-subtext">Selecciona un usuario para comenzar a chatear</div>
                </div>
            </div>

            <div class="input-area">
                <div class="input-wrapper">
                    <textarea 
                        class="message-input" 
                        id="messageInput" 
                        placeholder="Escribe tu mensaje..." 
                        rows="1"
                        disabled
                    ></textarea>
                    <button class="send-button" id="sendButton" disabled title="Enviar mensaje">
                        ➤
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Simulación de chat en tiempo real
        class ChatApp {
            constructor() {
                this.currentUser = null;
                this.selectedUser = null;
                this.conversations = new Map();
                this.users = [
                    { id: 1, name: 'Ana García', status: 'Conectado', avatar: 'AG' },
                    { id: 2, name: 'Carlos López', status: 'Conectado', avatar: 'CL' },
                    { id: 3, name: 'Diana Martínez', status: 'Conectado', avatar: 'DM' },
                    { id: 4, name: 'Eduardo Ruiz', status: 'Conectado', avatar: 'ER' },
                    { id: 5, name: 'Fernanda Silva', status: 'Conectado', avatar: 'FS' },
                ];

                this.currentUser = {
                    id: 0,
                    name: 'Tú',
                    status: 'Conectado',
                    avatar: 'TÚ'
                };

                this.initializeConversations();
                this.setupEventListeners();
                this.renderUsers();
                this.updateOnlineCount();
            }

            initializeConversations() {
                this.users.forEach(user => {
                    this.conversations.set(user.id, []);
                });
            }

            setupEventListeners() {
                const messageInput = document.getElementById('messageInput');
                const sendButton = document.getElementById('sendButton');

                messageInput.addEventListener('keydown', (e) => {
                    if (e.key === 'Enter' && !e.shiftKey) {
                        e.preventDefault();
                        this.sendMessage();
                    }
                });

                messageInput.addEventListener('input', (e) => {
                    e.target.style.height = 'auto';
                    e.target.style.height = Math.min(e.target.scrollHeight, 100) + 'px';
                });

                sendButton.addEventListener('click', () => this.sendMessage());
            }

            renderUsers() {
                const usersList = document.getElementById('usersList');
                const usersLabel = usersList.querySelector('.users-label');
                usersList.innerHTML = '<div class="users-label">Usuarios conectados</div>';

                this.users.forEach(user => {
                    const userItem = document.createElement('div');
                    userItem.className = 'user-item';
                    userItem.innerHTML = `
                        <div class="user-avatar">${user.avatar}</div>
                        <div class="user-info">
                            <div class="user-name">${user.name}</div>
                            <div class="user-status">${user.status}</div>
                        </div>
                        <div class="status-indicator"></div>
                    `;

                    userItem.addEventListener('click', () => this.selectUser(user));
                    usersList.appendChild(userItem);
                });
            }

            selectUser(user) {
                this.selectedUser = user;

                // Update active state
                document.querySelectorAll('.user-item').forEach((item, index) => {
                    if (index - 1 === this.users.indexOf(user)) {
                        item.classList.add('active');
                    } else {
                        item.classList.remove('active');
                    }
                });

                // Update header
                document.getElementById('selectedUserName').textContent = user.name;
                document.getElementById('selectedUserStatus').textContent = user.status;

                // Enable input
                document.getElementById('messageInput').disabled = false;
                document.getElementById('sendButton').disabled = false;

                // Render messages
                this.renderMessages();
            }

            sendMessage() {
                if (!this.selectedUser) return;

                const messageInput = document.getElementById('messageInput');
                const text = messageInput.value.trim();

                if (!text) return;

                const message = {
                    id: Date.now(),
                    author: this.currentUser.name,
                    authorId: this.currentUser.id,
                    text: text,
                    timestamp: new Date(),
                    isOwn: true
                };

                const conversation = this.conversations.get(this.selectedUser.id);
                conversation.push(message);

                // Simulate response
                setTimeout(() => {
                    const response = {
                        id: Date.now() + 1,
                        author: this.selectedUser.name,
                        authorId: this.selectedUser.id,
                        text: this.generateResponse(text),
                        timestamp: new Date(),
                        isOwn: false
                    };
                    conversation.push(response);
                    this.renderMessages();
                }, 500 + Math.random() * 1500);

                messageInput.value = '';
                messageInput.style.height = 'auto';
                this.renderMessages();
            }

            generateResponse(message) {
                const responses = [
                    '¡Qué interesante! 😊',
                    'Totalmente de acuerdo contigo',
                    'Me encanta tu idea',
                    'Exactamente lo que estaba pensando',
                    '¡Muy bien dicho!',
                    'Gracias por compartir eso',
                    'Tienes razón',
                    '¡Jajaja, me hizo reír! 😄',
                    'Déjame pensarlo...',
                    'Suena perfecto para mí'
                ];
                return responses[Math.floor(Math.random() * responses.length)];
            }

            renderMessages() {
                const messagesList = document.getElementById('messagesList');
                const conversation = this.conversations.get(this.selectedUser.id) || [];

                if (conversation.length === 0) {
                    messagesList.innerHTML = `
                        <div class="empty-state">
                            <div class="empty-state-icon">💭</div>
                            <div class="empty-state-text">Inicia la conversación</div>
                            <div class="empty-state-subtext">Sé el primero en enviar un mensaje a ${this.selectedUser.name}</div>
                        </div>
                    `;
                    return;
                }

                messagesList.innerHTML = conversation.map(msg => {
                    const time = msg.timestamp.toLocaleTimeString('es-ES', { hour: '2-digit', minute: '2-digit' });
                    const initials = msg.author.split(' ').map(n => n[0]).join('').toUpperCase();

                    return `
                        <div class="message ${msg.isOwn ? 'own' : ''}">
                            ${!msg.isOwn ? `<div class="message-avatar">${initials}</div>` : ''}
                            <div class="message-content">
                                ${!msg.isOwn ? `<div class="message-header"><span class="message-author">${msg.author}</span><span class="message-time">${time}</span></div>` : ''}
                                <div class="message-bubble">${this.escapeHtml(msg.text)}</div>
                                ${msg.isOwn ? `<div class="message-header"><span class="message-time">${time}</span></div>` : ''}
                            </div>
                        </div>
                    `;
                }).join('');

                // Scroll to bottom
                messagesList.scrollTop = messagesList.scrollHeight;
            }

            updateOnlineCount() {
                document.getElementById('onlineCount').textContent = `${this.users.length} conectados`;
            }

            escapeHtml(text) {
                const div = document.createElement('div');
                div.textContent = text;
                return div.innerHTML;
            }
        }

        // Initialize app
        document.addEventListener('DOMContentLoaded', () => {
            new ChatApp();
        });
    </script>
</body>
</html>
